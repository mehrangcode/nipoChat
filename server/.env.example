# --- Server ---
PORT=4000
# Comma-separated list of allowed client origins (CORS + Socket.IO)
CLIENT_ORIGIN=http://localhost:5173

# --- Auth ---
# Use a long random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# --- Web Push (VAPID) ---
# Generate with: npm run vapid   (or: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# --- Feature flags (isolated voice/video calls) ---
FEATURE_VOICE_CALL=true
FEATURE_VIDEO_CALL=true

# --- Uploads ---
# Max upload size in bytes (default 15 MB)
MAX_UPLOAD_BYTES=15728640
